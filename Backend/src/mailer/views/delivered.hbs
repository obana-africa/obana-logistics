<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; line-height: 1.6; color: #333; margin: 0; padding: 0; background-color: #f4f5f7; }
        .container { max-width: 560px; margin: 0 auto; background-color: #ffffff; }
        .header { background-color: #0f2233; padding: 28px; text-align: center; }
        .header h1 { margin: 0; font-size: 22px; color: #ffffff; }
        .header h1 .accent { color: #f5a623; }
        .content { padding: 28px; }
        .badge { display: inline-block; background-color: #e3f6ea; color: #1e874b; font-weight: bold; font-size: 13px; padding: 6px 14px; border-radius: 20px; margin-bottom: 16px; }
        .greeting { font-weight: bold; font-size: 16px; margin: 0 0 12px; }
        .lead { color: #4a5568; margin: 0 0 20px; }
        .row { margin-bottom: 8px; }
        .label { font-weight: bold; color: #1a202c; }
        .note { background-color: #f7f8fa; border-radius: 8px; padding: 16px; color: #4a5568; font-size: 14px; margin: 24px 0; }
        .btn-wrap { text-align: center; margin: 8px 0 24px; }
        .btn { display: inline-block; padding: 16px 24px; width: 80%; box-sizing: border-box; background-color: #1e874b; color: #ffffff !important; text-decoration: none; border-radius: 6px; font-weight: bold; }
        .hr { border: none; border-top: 1px solid #eee; margin: 24px 0; }
        .questions { text-align: center; color: #718096; font-size: 14px; }
        .questions a { color: #2b6cb0; }
        .footer { background-color: #f7f8fa; text-align: center; font-size: 12px; color: #a0aec0; padding: 20px; }
        .footer a { color: #4a5568; text-decoration: underline; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Obana <span class="accent">Logistics</span></h1>
        </div>

        <div class="content">
            <p class="greeting">Hello {{customer_name}},</p>

            <div class="badge">Delivered</div>

            <p class="lead">Your order {{order_ref}} has been delivered. Thank you for shipping with Obana!</p>

            <div class="row"><span class="label">Order Date:</span> {{order_date}}</div>
            <div class="row"><span class="label">Delivered On:</span> {{delivered_date}}</div>
            <div class="row"><span class="label">Delivery Address:</span> {{shipping_address}}</div>

            <div class="note">
                <strong>Note:</strong> If you did not receive this package or have any concerns, please contact us right away.
            </div>

            <div class="btn-wrap">
                <a href="{{tracking_url}}" class="btn">View Delivery Details  &rarr;</a>
            </div>

            <hr class="hr" />

            <p class="questions">Questions? <a href="mailto:logistics@obana.africa">logistics@obana.africa</a></p>
        </div>

        <div class="footer">
            <strong>Obana Logistics</strong> &nbsp;&middot;&nbsp;
            <a href="{{tracking_url}}">Track</a> &nbsp;&middot;&nbsp;
            <a href="mailto:logistics@obana.africa">Support</a>
            <div>&copy; {{year}} Obana Logistics</div>
        </div>
    </div>
</body>
</html>
